# Configura le tue credenziali Supabase per collegare il database reale
NEXT_PUBLIC_SUPABASE_URL=https://IL_TUO_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=LA_TUA_ANON_KEY

# Duffel: API di prenotazione voli (include easyJet via Direct Connect; NON include Ryanair)
DUFFEL_ACCESS_TOKEN=IL_TUO_TOKEN_DUFFEL

# RapidAPI: ricerca hotel (TripAdvisor)
RAPIDAPI_KEY=LA_TUA_RAPIDAPI_KEY

# Travelpayouts: marker affiliato usato nei link Aviasales (voli) e Booking.com (hotel)
AFFILIATE_MARKER=IL_TUO_MARKER_TRAVELPAYOUTS

# Kiwi.com affiliate id (programma Kiwi.com su Travelpayouts, ~3% a prenotazione).
# Se impostato, le offerte di compagnie low-cost (Ryanair/easyJet/Wizz/...) reindirizzano
# su Kiwi.com — OTA "approvato" Ryanair — invece che sul metasearch (che sui low-cost paga ~0%).
#
# Kiwi.com non ha un generatore di deep-link nell'interfaccia Travelpayouts: per ottenere
# questo valore vai su Travelpayouts > Programs > Kiwi.com > Links > "IT: Main page" >
# Copy link, apri il link copiato e leggi il parametro `affilid` nell'URL di destinazione
# (es. da https://www.kiwi.com/deep?affilid=travelpayoutsdeeplink_XXXXX&lang=it...
# copia solo il valore di affilid, senza gli altri parametri).
KIWI_AFFILIATE_ID=

# Travelpayouts Data API token (gratuito, da Profilo > API token) — per il tracking
# dei prezzi via api.travelpayouts.com/aviasales/v3/* (prezzi cache 2-7 giorni).
TRAVELPAYOUTS_TOKEN=

# DeepSeek: motore AI dietro la search bar della home (ricerca in linguaggio
# naturale + composizione di pacchetti volo+hotel). Chiave da platform.deepseek.com
# > API keys. Usata SOLO lato server (src/pages/api/ai-search.ts, mai esposta al
# browser). Se non impostata, la ricerca ricade su un filtro locale per parola
# chiave: nessun errore, solo meno "smart".
DEEPSEEK_API_KEY=
