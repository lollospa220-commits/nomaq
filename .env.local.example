# Configura le tue credenziali Supabase per collegare il database reale
NEXT_PUBLIC_SUPABASE_URL=https://IL_TUO_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=LA_TUA_ANON_KEY

# Duffel: API di prenotazione voli (include easyJet via Direct Connect; NON include Ryanair)
DUFFEL_ACCESS_TOKEN=IL_TUO_TOKEN_DUFFEL

# RapidAPI: ricerca hotel (TripAdvisor)
RAPIDAPI_KEY=LA_TUA_RAPIDAPI_KEY

# Travelpayouts: marker affiliato usato nei link Booking.com (hotel)
AFFILIATE_MARKER=IL_TUO_MARKER_TRAVELPAYOUTS

# Kiwi.com affiliate id (programma Kiwi.com su Travelpayouts, ~3% a prenotazione).
# Tutti i link voli puntano a Kiwi.com (nessun sito russo tipo Aviasales/Jetradar);
# se impostato il click viene tracciato e genera commissione, se vuoto il link
# resta comunque un normale link di ricerca Kiwi.com funzionante.
#
# Kiwi.com non ha un generatore di deep-link nell'interfaccia Travelpayouts: per ottenere
# questo valore vai su Travelpayouts > Programs > Kiwi.com > Links > "IT: Main page" >
# Copy link, apri il link copiato e leggi il parametro `affilid` nell'URL di destinazione
# (es. da https://www.kiwi.com/deep?affilid=travelpayoutsdeeplink_XXXXX&lang=it...
# copia solo il valore di affilid, senza gli altri parametri).
KIWI_AFFILIATE_ID=

# Mistral (UE): motore AI dietro la search bar della home (ricerca in linguaggio
# naturale + composizione di pacchetti volo+hotel) e dietro il Concierge. Chiave
# da console.mistral.ai. Usata SOLO lato server (src/pages/api/ai-trip.ts e
# src/pages/api/concierge.ts, mai esposta al browser). Se non impostata, la
# ricerca ricade su un filtro locale per parola chiave: nessun errore, solo meno "smart".
MISTRAL_API_KEY=
# Modello Mistral da usare (opzionale; il codice ha un default), es. mistral-small-latest
MISTRAL_MODEL=

# Token gratuito da https://app.travelpayouts.com > Profilo > API token —
# abilita i prezzi voli reali (cache di mercato Aviasales) al posto dei seed.
TRAVELPAYOUTS_TOKEN=
